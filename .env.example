OPENAI_PROJECT_ID=proj_...        # opcional, para /usage filtrado por proyecto

# === Meta Graph API (Instagram Stories + Posts) ===
META_GRAPH_TOKEN=EAANgOwK...
META_IG_USER_ID=178414...

# === API key para escritura externa de stories/posts (n8n, webhooks) ===
