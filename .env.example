# === Postgres (memoria persistente del catálogo) ===
DATABASE_URL=postgres://user:pass@host:5432/dbname?sslmode=disable

# === OpenAI ===
OPENAI_API_KEY=sk-proj-...
OPENAI_VECTOR_STORE_ID=vs_...
